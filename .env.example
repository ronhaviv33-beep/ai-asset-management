# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here

# ── Anthropic (claude-opus-4, claude-sonnet-4, claude-haiku-4) ─
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Google (gemini-2.0-pro, gemini-2.0-flash, gemini-1.5-pro) ──
GOOGLE_API_KEY=your-google-api-key-here

# ── Local models via Ollama / vLLM / LM Studio ────────────────
LOCAL_LLM_URL=http://localhost:11434/v1

# ── JWT signing secret (change before deploying) ──────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string-32chars

# ── Gateway fail mode ─────────────────────────────────────────
# closed (default): enforcement errors block the request
# open:             enforcement errors are logged but the request passes through
GATEWAY_FAIL_MODE=closed

# ── Admin seed password (first-run only, ignored if admin already exists) ─────
# Change this before first launch. After the admin is created, update via UI.
ADMIN_SEED_PASSWORD=Ch@ngeMe!FinOps2026#

# ── CORS allowed origin (set to your frontend URL) ────────────────────────────
# Local dev: leave blank (defaults to localhost:5173)
# Production: set to your Render frontend URL e.g. https://aifinops-frontend.onrender.com
FRONTEND_ORIGIN=

# ── Debug mode (enables /docs Swagger UI — never enable in production) ────────
DEBUG=false
